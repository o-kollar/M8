# .env.example - Copy this to .env and fill in your values

# Server Configuration
PORT=3000
LOG_LEVEL=info

# Gemini API Configuration
# Get your API key from: https://console.cloud.google.com/apis/credentials
GEMINI_API_KEY=your_gemini_api_key_here

# Replicate API Configuration (optional)
# Get your API token from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your_replicate_api_token_here

# Localtunnel Configuration (optional)
# Set to 'true' to enable automatic public URL tunneling
ENABLE_LOCALTUNNEL=false
# Optional: specify a custom subdomain for localtunnel
LOCALTUNNEL_SUBDOMAIN=
